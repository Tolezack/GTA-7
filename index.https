<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>GTA 7 - Cidade Aberta 3D</title>
    <meta name="description" content="Jogo estilo GTA em 3D com cidade aberta, veículos e armas">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            font-family: 'Arial', sans-serif;
            background: #000;
        }
        
        #gameCanvas {
            display: block;
            width: 100vw;
            height: 100vh;
        }
        
        #ui {
            position: absolute;
            top: 20px;
            left: 20px;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
            z-index: 10;
            background: rgba(0,0,0,0.6);
            padding: 15px;
            border-radius: 10px;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,215,0,0.3);
            pointer-events: none;
        }
        
        #hud {
            position: absolute;
            bottom: 30px;
            left: 30px;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
            z-index: 10;
            font-size: 16px;
            background: rgba(0,0,0,0.6);
            padding: 10px;
            border-radius: 10px;
            backdrop-filter: blur(5px);
            pointer-events: none;
        }
        
        #weaponHud {
            position: absolute;
            bottom: 30px;
            right: 30px;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
            z-index: 10;
            font-size: 16px;
            text-align: right;
            background: rgba(0,0,0,0.6);
            padding: 10px;
            border-radius: 10px;
            backdrop-filter: blur(5px);
            pointer-events: none;
        }
        
        #minimap {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 180px;
            height: 180px;
            background: rgba(0,0,0,0.7);
            border: 2px solid rgba(255,215,0,0.5);
            border-radius: 10px;
            z-index: 10;
            backdrop-filter: blur(5px);
            pointer-events: none;
        }
        
        #instructions {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            color: white;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.8);
            z-index: 10;
            font-size: 14px;
            text-align: center;
            background: rgba(0,0,0,0.7);
            padding: 8px 15px;
            border-radius: 10px;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,215,0,0.3);
            white-space: nowrap;
            pointer-events: none;
        }
        
        #healthBar, #armorBar {
            position: absolute;
            left: 30px;
            width: 180px;
            height: 18px;
            background: rgba(0,0,0,0.7);
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 9px;
            overflow: hidden;
            pointer-events: none;
        }
        
        #healthBar { bottom: 80px; }
        #armorBar { bottom: 55px; }
        
        #healthFill {
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, #ff0000, #ff4444);
            transition: width 0.3s;
        }
        
        #armorFill {
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, #0066ff, #4488ff);
            transition: width 0.3s;
        }
        
        #message {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
            z-index: 20;
            font-size: 20px;
            text-align: center;
            opacity: 0;
            transition: opacity 0.3s;
            background: rgba(0,0,0,0.8);
            padding: 15px 25px;
            border-radius: 10px;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,215,0,0.5);
            pointer-events: none;
        }
        
        #crosshair {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 30px;
            height: 30px;
            z-index: 15;
            pointer-events: none;
        }
        
        #crosshair::before,
        #crosshair::after {
            content: '';
            position: absolute;
            background: rgba(255,255,255,0.9);
            box-shadow: 0 0 3px rgba(0,0,0,0.5);
        }
        
        #crosshair::before {
            width: 2px;
            height: 16px;
            left: 14px;
            top: 7px;
        }
        
        #crosshair::after {
            width: 16px;
            height: 2px;
            left: 7px;
            top: 14px;
        }
        
        #wantedLevel {
            position: absolute;
            top: 20px;
            right: 220px;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
            z-index: 10;
            font-size: 16px;
            background: rgba(0,0,0,0.6);
            padding: 10px;
            border-radius: 10px;
            backdrop-filter: blur(5px);
            pointer-events: none;
        }
        
        #clickToStart {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            z-index: 30;
            font-size: 24px;
            text-align: center;
            background: rgba(0,0,0,0.8);
            padding: 20px 40px;
            border-radius: 15px;
            backdrop-filter: blur(5px);
            border: 2px solid rgba(255,215,0,0.5);
            cursor: pointer;
            transition: all 0.3s;
            pointer-events: auto;
        }
        
        #clickToStart:hover {
            transform: translate(-50%, -50%) scale(1.05);
            background: rgba(0,0,0,0.9);
            border-color: #ffd700;
        }
        
        #gameOverMenu {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.85);
            z-index: 100;
            display: none;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(5px);
            pointer-events: auto;
        }
        
        .gameover-content {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            padding: 40px;
            border-radius: 20px;
            text-align: center;
            border: 2px solid #ff4444;
            box-shadow: 0 0 50px rgba(255,0,0,0.3);
        }
        
        .gameover-content h1 {
            color: #ff4444;
            font-size: 48px;
            margin: 0 0 20px 0;
            text-shadow: 0 0 20px rgba(255,0,0,0.5);
        }
        
        .gameover-stats {
            color: white;
            font-size: 18px;
            margin: 20px 0;
            padding: 15px;
            background: rgba(0,0,0,0.3);
            border-radius: 10px;
        }
        
        .gameover-stats div {
            margin: 10px 0;
        }
        
        .restart-btn {
            background: linear-gradient(135deg, #ff4444 0%, #cc0000 100%);
            color: white;
            border: none;
            padding: 15px 40px;
            font-size: 20px;
            border-radius: 10px;
            cursor: pointer;
            margin: 10px;
            transition: transform 0.2s, box-shadow 0.2s;
            border: 2px solid #ff8888;
            font-weight: bold;
        }
        
        .restart-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 30px rgba(255,0,0,0.5);
        }
        
        .quit-btn {
            background: linear-gradient(135deg, #444 0%, #222 100%);
            color: white;
            border: none;
            padding: 15px 40px;
            font-size: 20px;
            border-radius: 10px;
            cursor: pointer;
            margin: 10px;
            transition: transform 0.2s;
            border: 2px solid #888;
        }
        
        .quit-btn:hover {
            transform: scale(1.05);
            background: linear-gradient(135deg, #555 0%, #333 100%);
        }
        
        .low-ammo {
            color: #ff4444 !important;
            animation: pulse 0.5s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        #pointerLockMessage {
            position: absolute;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            color: rgba(255,255,255,0.7);
            z-index: 15;
            font-size: 14px;
            background: rgba(0,0,0,0.5);
            padding: 5px 15px;
            border-radius: 20px;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        #loading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            z-index: 5;
            font-size: 18px;
            background: rgba(0,0,0,0.7);
            padding: 15px 30px;
            border-radius: 10px;
        }
        
        #version {
            position: absolute;
            bottom: 10px;
            right: 10px;
            color: rgba(255,255,255,0.5);
            font-size: 12px;
            z-index: 10;
            pointer-events: none;
        }
    </style>
</head>
<body>
    <div id="ui">
        <h2 style="margin:0 0 10px 0;">🚗 GTA 7 - Cidade do Crime</h2>
        <div>💰 Dinheiro: R$ <span id="money">10.000</span></div>
        <div>🎯 Mortes: <span id="kills">0</span></div>
    </div>
    
    <div id="wantedLevel">
        <div>⭐ Nível de Procurado</div>
        <div id="stars">☆☆☆☆☆</div>
    </div>
    
    <div id="minimap">
        <canvas id="minimapCanvas" width="180" height="180"></canvas>
    </div>
    
    <div id="hud">
        <div>🏃 Velocidade: <span id="speed">0</span> km/h</div>
        <div>🚗 Veículo: <span id="vehicle">A Pé</span></div>
    </div>
    
    <div id="healthBar">
        <div id="healthFill"></div>
    </div>
    
    <div id="armorBar">
        <div id="armorFill"></div>
    </div>
    
    <div id="weaponHud">
        <div>🔫 <span id="weapon">Pistola</span></div>
        <div>💣 <span id="ammoDisplay">30/30</span></div>
    </div>
    
    <div id="instructions">
        🎮 WASD - Mover | 🖱️ Mouse - Olhar | 🔫 Click - Atirar | 🚗 F - Entrar/Sair | 📦 E - Pegar Arma | R - Recarregar | ESC - Soltar Mouse
    </div>
    
    <div id="crosshair"></div>
    <div id="message"></div>
    <div id="pointerLockMessage">🔒 Pressione ESC para soltar o mouse</div>
    <div id="loading">🚀 Carregando cidade 3D...</div>
    <div id="version">v1.0.0 | GTA 7</div>
    
    <div id="clickToStart">
        🎮 CLIQUE PARA JOGAR 🎮
    </div>
    
    <div id="gameOverMenu">
        <div class="gameover-content">
            <h1>💀 GAME OVER 💀</h1>
            <div class="gameover-stats">
                <div>🏆 Mortes: <span id="finalKills">0</span></div>
                <div>💰 Dinheiro Final: R$ <span id="finalMoney">0</span></div>
                <div>⭐ Nível de Procurado: <span id="finalWanted">0</span></div>
                <div>🎯 Precisão: <span id="accuracy">0%</span></div>
            </div>
            <button class="restart-btn" onclick="location.reload()">🔄 JOGAR NOVAMENTE</button>
            <button class="quit-btn" onclick="window.location.href='https://github.com'">🚪 SAIR</button>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
        (function() {
            "use strict";
            
            // Configuração
            const scene = new THREE.Scene();
            scene.fog = new THREE.FogExp2(0x87CEEB, 0.003);
            
            const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(0, 8, 15);
            
            const renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFShadowMap;
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            document.body.appendChild(renderer.domElement);
            
            // Iluminação
            const ambientLight = new THREE.AmbientLight(0x404060, 0.5);
            scene.add(ambientLight);
            
            const sunLight = new THREE.DirectionalLight(0xffeedd, 1);
            sunLight.position.set(30, 50, 30);
            sunLight.castShadow = true;
            sunLight.receiveShadow = true;
            sunLight.shadow.mapSize.width = 1024;
            sunLight.shadow.mapSize.height = 1024;
            const d = 100;
            sunLight.shadow.camera.left = -d;
            sunLight.shadow.camera.right = d;
            sunLight.shadow.camera.top = d;
            sunLight.shadow.camera.bottom = -d;
            sunLight.shadow.camera.near = 1;
            sunLight.shadow.camera.far = 150;
            scene.add(sunLight);
            
            scene.background = new THREE.Color(0x87CEEB);
            
            // Variáveis do jogo
            const keys = {};
            let gameRunning = false;
            let pointerLocked = false;
            let shotsFired = 0;
            let shotsHit = 0;
            
            const player = {
                health: 100,
                armor: 50,
                money: 10000,
                wanted: 0,
                kills: 0,
                inVehicle: false,
                currentVehicle: null,
                weapon: 'Pistola',
                weaponDamage: 25,
                ammo: 30,
                maxAmmo: 30,
                isReloading: false
            };
            
            const vehicles = [];
            const buildings = [];
            const enemies = [];
            const weapons = [];
            const bullets = [];
            
            const weaponTypes = {
                'Pistola': { damage: 25, color: 0x888888, ammo: 30, fireRate: 200 },
                'Shotgun': { damage: 50, color: 0x8B4513, ammo: 8, fireRate: 800 },
                'Rifle': { damage: 35, color: 0x2F4F4F, ammo: 30, fireRate: 100 },
                'SMG': { damage: 20, color: 0x696969, ammo: 50, fireRate: 50 }
            };
            
            let cameraRotation = { x: 0, y: 0 };
            const euler = new THREE.Euler(0, 0, 0, 'YXZ');
            const PI_2 = Math.PI / 2;
            
            // Pointer Lock
            renderer.domElement.addEventListener('click', () => {
                if (!gameRunning) {
                    startGame();
                }
                renderer.domElement.requestPointerLock();
            });
            
            document.addEventListener('pointerlockchange', () => {
                pointerLocked = document.pointerLockElement === renderer.domElement;
                document.getElementById('pointerLockMessage').style.opacity = pointerLocked ? '1' : '0';
            });
            
            document.addEventListener('mousemove', (e) => {
                if (!gameRunning || !pointerLocked || player.inVehicle) return;
                
                const movementX = e.movementX || 0;
                const movementY = e.movementY || 0;
                
                cameraRotation.y -= movementX * 0.002;
                cameraRotation.x -= movementY * 0.002;
                cameraRotation.x = Math.max(-PI_2, Math.min(PI_2, cameraRotation.x));
                
                euler.x = cameraRotation.x;
                euler.y = cameraRotation.y;
                camera.quaternion.setFromEuler(euler);
            });
            
            function startGame() {
                gameRunning = true;
                document.getElementById('clickToStart').style.display = 'none';
                document.getElementById('loading').style.display = 'none';
                showMessage("🎮 Jogo iniciado!", 2000);
            }
            
            document.addEventListener('keydown', (e) => {
                if (!gameRunning) return;
                keys[e.code] = true;
                if (e.code === 'KeyF') toggleVehicle();
                if (e.code === 'KeyE') pickupWeapon();
                if (e.code === 'KeyR') reloadWeapon();
            });
            document.addEventListener('keyup', (e) => keys[e.code] = false);
            
            let lastShot = 0;
            renderer.domElement.addEventListener('mousedown', (e) => {
                if (!gameRunning || !pointerLocked) return;
                if (e.button === 0 && !player.inVehicle && !player.isReloading) {
                    const now = Date.now();
                    if (now - lastShot > weaponTypes[player.weapon].fireRate) {
                        shoot();
                        lastShot = now;
                    }
                }
            });
            
            function reloadWeapon() {
                if (!gameRunning || player.isReloading || player.ammo === player.maxAmmo) return;
                
                player.isReloading = true;
                showMessage("🔄 Recarregando...", 1500);
                
                setTimeout(() => {
                    player.ammo = player.maxAmmo;
                    player.isReloading = false;
                    showMessage("✅ Arma recarregada!", 1000);
                    updateUI();
                }, 1500);
            }
            
            function createWorld() {
                const ground = new THREE.Mesh(
                    new THREE.CircleGeometry(200, 32),
                    new THREE.MeshStandardMaterial({ color: 0x3a5f0b, roughness: 0.9 })
                );
                ground.rotation.x = -Math.PI / 2;
                ground.receiveShadow = true;
                ground.position.y = 0;
                scene.add(ground);
                
                const grid = new THREE.GridHelper(400, 40, 0x000000, 0x444444);
                grid.position.y = 0.01;
                scene.add(grid);
                
                createCity();
                createVehicles();
                createEnemies();
                createWeapons();
                createDecorations();
            }
            
            function createCity() {
                const colors = [0x8B8B8B, 0xA9A9A9, 0x808080, 0x696969, 0x778899];
                
                for (let x = -120; x <= 120; x += 25) {
                    for (let z = -120; z <= 120; z += 25) {
                        if (Math.abs(x) < 15 && Math.abs(z) < 15) continue;
                        
                        const height = 5 + Math.floor(Math.random() * 20);
                        const building = new THREE.Mesh(
                            new THREE.BoxGeometry(7, height, 7),
                            new THREE.MeshStandardMaterial({ 
                                color: colors[Math.floor(Math.random() * colors.length)],
                                roughness: 0.4
                            })
                        );
                        
                        building.position.set(x, height/2, z);
                        building.castShadow = true;
                        building.receiveShadow = true;
                        
                        scene.add(building);
                        buildings.push(building);
                    }
                }
            }
            
            function createVehicles() {
                const positions = [
                    [-20, 0.5, -15], [25, 0.5, 20], [-35, 0.5, 30], [40, 0.5, -25],
                    [-50, 0.5, 10], [15, 0.5, -40]
                ];
                
                positions.forEach((pos, i) => {
                    const types = ['🚗 Sedan', '🚙 SUV', '🏎️ Esportivo'];
                    createVehicle(pos[0], pos[1], pos[2], types[i % 3]);
                });
            }
            
            function createVehicle(x, y, z, type) {
                const group = new THREE.Group();
                const colors = [0xff3333, 0x3333ff, 0x33ff33, 0xffaa00];
                
                const body = new THREE.Mesh(
                    new THREE.BoxGeometry(2.2, 0.5, 4.5),
                    new THREE.MeshStandardMaterial({ 
                        color: colors[Math.floor(Math.random() * colors.length)],
                        roughness: 0.3,
                        metalness: 0.6
                    })
                );
                body.position.y = 0.5;
                body.castShadow = true;
                body.receiveShadow = true;
                group.add(body);
                
                const cabin = new THREE.Mesh(
                    new THREE.BoxGeometry(1.3, 0.5, 1.8),
                    new THREE.MeshStandardMaterial({ 
                        color: 0xaaccff,
                        transparent: true,
                        opacity: 0.6
                    })
                );
                cabin.position.y = 1;
                cabin.position.z = -0.3;
                cabin.castShadow = true;
                cabin.receiveShadow = true;
                group.add(cabin);
                
                const wheelGeo = new THREE.CylinderGeometry(0.4, 0.4, 0.3, 8);
                const wheelMat = new THREE.MeshStandardMaterial({ color: 0x222222 });
                
                [[-0.9, 0.3, 1.3], [0.9, 0.3, 1.3], [-0.9, 0.3, -1.3], [0.9, 0.3, -1.3]].forEach(pos => {
                    const wheel = new THREE.Mesh(wheelGeo, wheelMat);
                    wheel.rotation.z = Math.PI / 2;
                    wheel.position.set(pos[0], pos[1], pos[2]);
                    wheel.castShadow = true;
                    group.add(wheel);
                });
                
                group.position.set(x, y, z);
                group.userData = {
                    type: type,
                    speed: 0,
                    maxSpeed: type === '🏎️ Esportivo' ? 0.6 : 0.4,
                    acceleration: 0.015,
                    turnSpeed: 0.025
                };
                
                scene.add(group);
                vehicles.push(group);
            }
            
            function createEnemies() {
                for (let i = 0; i < 8; i++) {
                    const enemy = new THREE.Mesh(
                        new THREE.CylinderGeometry(0.6, 0.6, 2, 8),
                        new THREE.MeshStandardMaterial({ color: 0xcc0000 })
                    );
                    
                    const angle = (i / 8) * Math.PI * 2;
                    const radius = 50;
                    enemy.position.x = Math.cos(angle) * radius;
                    enemy.position.z = Math.sin(angle) * radius;
                    enemy.position.y = 1;
                    
                    enemy.castShadow = true;
                    enemy.receiveShadow = true;
                    
                    enemy.userData = {
                        health: 100,
                        speed: 0.05,
                        damage: 5
                    };
                    
                    scene.add(enemy);
                    enemies.push(enemy);
                }
            }
            
            function createWeapons() {
                for (let i = 0; i < 12; i++) {
                    const angle = Math.random() * Math.PI * 2;
                    const radius = 30 + Math.random() * 50;
                    const x = Math.cos(angle) * radius;
                    const z = Math.sin(angle) * radius;
                    const type = Object.keys(weaponTypes)[Math.floor(Math.random() * 4)];
                    
                    const group = new THREE.Group();
                    const data = weaponTypes[type];
                    
                    const weapon = new THREE.Mesh(
                        new THREE.BoxGeometry(0.8, 0.2, 0.4),
                        new THREE.MeshStandardMaterial({ 
                            color: data.color,
                            emissive: new THREE.Color(0x333333),
                            emissiveIntensity: 0.3
                        })
                    );
                    weapon.position.y = 0.3;
                    weapon.castShadow = true;
                    group.add(weapon);
                    
                    const light = new THREE.PointLight(0xffaa00, 0.5, 4);
                    light.position.y = 1;
                    group.add(light);
                    
                    group.position.set(x, 0.2, z);
                    group.userData = { type: type, damage: data.damage, ammo: data.ammo };
                    
                    scene.add(group);
                    weapons.push(group);
                }
            }
            
            function createDecorations() {
                for (let i = 0; i < 16; i++) {
                    const angle = (i / 16) * Math.PI * 2;
                    const radius = 35;
                    
                    const pole = new THREE.Mesh(
                        new THREE.CylinderGeometry(0.2, 0.3, 6),
                        new THREE.MeshStandardMaterial({ color: 0x888888 })
                    );
                    pole.position.set(Math.cos(angle) * radius, 3, Math.sin(angle) * radius);
                    pole.castShadow = true;
                    pole.receiveShadow = true;
                    scene.add(pole);
                    
                    const light = new THREE.PointLight(0xffaa66, 0.6, 25);
                    light.position.set(pole.position.x, 5.5, pole.position.z);
                    scene.add(light);
                }
            }
            
            function shoot() {
                if (player.ammo <= 0) {
                    showMessage("⚠️ Sem munição! Pressione R para recarregar", 1500);
                    return;
                }
                
                shotsFired++;
                
                const bullet = new THREE.Mesh(
                    new THREE.SphereGeometry(0.15),
                    new THREE.MeshStandardMaterial({ 
                        color: 0xffaa00,
                        emissive: new THREE.Color(0xff4400),
                        emissiveIntensity: 1
                    })
                );
                
                bullet.position.copy(camera.position);
                
                const direction = new THREE.Vector3(0, 0, -1);
                direction.applyQuaternion(camera.quaternion);
                bullet.userData.velocity = direction.multiplyScalar(1.5);
                bullet.userData.damage = player.weaponDamage;
                
                scene.add(bullet);
                bullets.push(bullet);
                
                player.ammo--;
                
                if (player.ammo === 0) {
                    setTimeout(() => reloadWeapon(), 500);
                }
                
                updateUI();
            }
            
            function pickupWeapon() {
                let nearest = null;
                let minDist = 3;
                
                weapons.forEach(w => {
                    const dist = camera.position.distanceTo(w.position);
                    if (dist < minDist) {
                        minDist = dist;
                        nearest = w;
                    }
                });
                
                if (nearest) {
                    const type = nearest.userData.type;
                    player.weapon = type;
                    player.weaponDamage = weaponTypes[type].damage;
                    player.maxAmmo = weaponTypes[type].ammo;
                    player.ammo = player.maxAmmo;
                    
                    scene.remove(nearest);
                    weapons.splice(weapons.indexOf(nearest), 1);
                    
                    showMessage(`🔫 ${type} adquirida!`, 1500);
                    updateUI();
                }
            }
            
            function toggleVehicle() {
                if (!player.inVehicle) {
                    let nearest = null;
                    let minDist = 4;
                    
                    vehicles.forEach(v => {
                        const dist = camera.position.distanceTo(v.position);
                        if (dist < minDist) {
                            minDist = dist;
                            nearest = v;
                        }
                    });
                    
                    if (nearest) {
                        player.inVehicle = true;
                        player.currentVehicle = nearest;
                        showMessage(`🚗 Entrou no ${nearest.userData.type}`, 1500);
                    }
                } else {
                    player.inVehicle = false;
                    camera.position.copy(player.currentVehicle.position);
                    camera.position.y += 3;
                    camera.position.x += 3;
                    camera.position.z += 3;
                    player.currentVehicle = null;
                    showMessage("🚶 Saiu do veículo", 1500);
                }
            }
            
            function gameOver() {
                gameRunning = false;
                document.exitPointerLock();
                
                const accuracy = shotsFired > 0 ? ((shotsHit / shotsFired) * 100).toFixed(1) : 0;
                
                document.getElementById('finalKills').textContent = player.kills;
                document.getElementById('finalMoney').textContent = player.money.toLocaleString();
                document.getElementById('finalWanted').textContent = player.wanted;
                document.getElementById('accuracy').textContent = accuracy + '%';
                
                document.getElementById('gameOverMenu').style.display = 'flex';
                showMessage("💀 GAME OVER", 999999);
            }
            
            function showMessage(text, duration) {
                const msg = document.getElementById('message');
                msg.textContent = text;
                msg.style.opacity = '1';
                setTimeout(() => {
                    if (msg.textContent === text) {
                        msg.style.opacity = '0';
                    }
                }, duration);
            }
            
            function updateUI() {
                document.getElementById('money').textContent = player.money.toLocaleString();
                document.getElementById('kills').textContent = player.kills;
                document.getElementById('healthFill').style.width = Math.max(0, player.health) + '%';
                document.getElementById('armorFill').style.width = Math.max(0, player.armor) + '%';
                
                const stars = Array(5).fill('☆').map((s, i) => i < player.wanted ? '⭐' : '☆').join('');
                document.getElementById('stars').innerHTML = stars;
                
                document.getElementById('weapon').textContent = player.weapon;
                
                const ammoDisplay = document.getElementById('ammoDisplay');
                ammoDisplay.textContent = `${player.ammo}/${player.maxAmmo}`;
                
                if (player.ammo <= player.maxAmmo * 0.2) {
                    ammoDisplay.classList.add('low-ammo');
                } else {
                    ammoDisplay.classList.remove('low-ammo');
                }
                
                if (player.inVehicle && player.currentVehicle) {
                    document.getElementById('vehicle').textContent = player.currentVehicle.userData.type;
                    document.getElementById('speed').textContent = Math.abs(player.currentVehicle.userData.speed * 120).toFixed(0);
                } else {
                    document.getElementById('vehicle').textContent = 'A Pé';
                    document.getElementById('speed').textContent = '0';
                }
            }
            
            function updateMinimap() {
                const canvas = document.getElementById('minimapCanvas');
                const ctx = canvas.getContext('2d');
                const scale = 0.9;
                
                ctx.fillStyle = '#1a1a2e';
                ctx.fillRect(0, 0, 180, 180);
                
                ctx.fillStyle = '#666';
                buildings.forEach(b => {
                    const x = 90 + b.position.x * scale;
                    const z = 90 + b.position.z * scale;
                    ctx.fillRect(x - 2, z - 2, 4, 4);
                });
                
                ctx.fillStyle = '#00f';
                vehicles.forEach(v => {
                    const x = 90 + v.position.x * scale;
                    const z = 90 + v.position.z * scale;
                    ctx.fillRect(x - 2, z - 2, 4, 4);
                });
                
                ctx.fillStyle = '#ff0';
                weapons.forEach(w => {
                    const x = 90 + w.position.x * scale;
                    const z = 90 + w.position.z * scale;
                    ctx.beginPath();
                    ctx.arc(x, z, 2, 0, Math.PI * 2);
                    ctx.fill();
                });
                
                ctx.fillStyle = '#f00';
                enemies.forEach(e => {
                    const x = 90 + e.position.x * scale;
                    const z = 90 + e.position.z * scale;
                    ctx.beginPath();
                    ctx.arc(x, z, 2, 0, Math.PI * 2);
                    ctx.fill();
                });
                
                ctx.fillStyle = player.inVehicle ? '#0f0' : '#fff';
                ctx.strokeStyle = '#000';
                ctx.lineWidth = 1.5;
                const px = 90 + camera.position.x * scale;
                const pz = 90 + camera.position.z * scale;
                ctx.beginPath();
                ctx.arc(px, pz, 3, 0, Math.PI * 2);
                ctx.fill();
                ctx.stroke();
            }
            
            function animate() {
                requestAnimationFrame(animate);
                
                if (!gameRunning) {
                    renderer.render(scene, camera);
                    return;
                }
                
                const moveSpeed = 0.25;
                
                if (player.inVehicle && player.currentVehicle) {
                    const v = player.currentVehicle;
                    
                    if (keys['KeyW']) v.userData.speed = Math.min(v.userData.speed + v.userData.acceleration, v.userData.maxSpeed);
                    if (keys['KeyS']) v.userData.speed = Math.max(v.userData.speed - v.userData.acceleration, -v.userData.maxSpeed/2);
                    
                    v.userData.speed *= 0.97;
                    
                    if (keys['KeyA']) v.rotation.y += v.userData.turnSpeed;
                    if (keys['KeyD']) v.rotation.y -= v.userData.turnSpeed;
                    
                    v.position.x += Math.sin(v.rotation.y) * v.userData.speed;
                    v.position.z += Math.cos(v.rotation.y) * v.userData.speed;
                    
                    v.position.x = Math.max(-130, Math.min(130, v.position.x));
                    v.position.z = Math.max(-130, Math.min(130, v.position.z));
                    
                    camera.position.set(
                        v.position.x - Math.sin(v.rotation.y) * 10,
                        v.position.y + 5,
                        v.position.z - Math.cos(v.rotation.y) * 10
                    );
                    camera.lookAt(v.position.clone().add(new THREE.Vector3(0, 1, 0)));
                    
                } else {
                    if (pointerLocked) {
                        const forward = new THREE.Vector3(0, 0, -1);
                        const right = new THREE.Vector3(1, 0, 0);
                        
                        forward.applyQuaternion(camera.quaternion);
                        right.applyQuaternion(camera.quaternion);
                        
                        forward.y = 0;
                        right.y = 0;
                        forward.normalize();
                        right.normalize();
                        
                        if (keys['KeyW']) {
                            camera.position.x += forward.x * moveSpeed;
                            camera.position.z += forward.z * moveSpeed;
                        }
                        if (keys['KeyS']) {
                            camera.position.x -= forward.x * moveSpeed;
                            camera.position.z -= forward.z * moveSpeed;
                        }
                        if (keys['KeyA']) {
                            camera.position.x -= right.x * moveSpeed;
                            camera.position.z -= right.z * moveSpeed;
                        }
                        if (keys['KeyD']) {
                            camera.position.x += right.x * moveSpeed;
                            camera.position.z += right.z * moveSpeed;
                        }
                    }
                    
                    camera.position.x = Math.max(-140, Math.min(140, camera.position.x));
                    camera.position.z = Math.max(-140, Math.min(140, camera.position.z));
                    camera.position.y = 2;
                }
                
                for (let i = bullets.length - 1; i >= 0; i--) {
                    const b = bullets[i];
                    b.position.add(b.userData.velocity);
                    
                    let hit = false;
                    
                    for (let j = enemies.length - 1; j >= 0; j--) {
                        const e = enemies[j];
                        if (b.position.distanceTo(e.position) < 1.5) {
                            e.userData.health -= b.userData.damage;
                            shotsHit++;
                            
                            if (e.userData.health <= 0) {
                                scene.remove(e);
                                enemies.splice(j, 1);
                                player.money += 100;
                                player.kills++;
                                player.wanted = Math.min(5, player.wanted + 1);
                                showMessage(`💰 +R$100`, 800);
                            }
                            
                            hit = true;
                            break;
                        }
                    }
                    
                    if (hit || b.position.length() > 150) {
                        scene.remove(b);
                        bullets.splice(i, 1);
                    }
                }
                
                enemies.forEach(e => {
                    const dx = camera.position.x - e.position.x;
                    const dz = camera.position.z - e.position.z;
                    const dist = Math.sqrt(dx*dx + dz*dz);
                    
                    if (dist > 2) {
                        const dirX = dx / dist;
                        const dirZ = dz / dist;
                        
                        e.position.x += dirX * e.userData.speed;
                        e.position.z += dirZ * e.userData.speed;
                    }
                    
                    e.position.y = 1;
                    
                    if (dist < 2) {
                        if (player.armor > 0) {
                            player.armor -= e.userData.damage;
                        } else {
                            player.health -= e.userData.damage;
                        }
                        
                        if (player.health <= 0) {
                            player.health = 0;
                            gameOver();
                        }
                        
                        e.position.x -= dx / dist * 0.5;
                        e.position.z -= dz / dist * 0.5;
                    }
                });
                
                weapons.forEach((w, i) => {
                    w.position.y = 0.3 + Math.sin(Date.now() * 0.005 + i) * 0.1;
                    w.rotation.y += 0.01;
                });
                
                if (player.health < 100 && player.wanted === 0 && Math.random() < 0.005) {
                    player.health = Math.min(100, player.health + 1);
                }
                
                if (player.wanted > 0 && Math.random() < 0.002) {
                    player.wanted = Math.max(0, player.wanted - 1);
                }
                
                if (enemies.length < 5 && Math.random() < 0.01) {
                    createEnemies();
                }
                
                updateUI();
                updateMinimap();
                
                renderer.render(scene, camera);
            }
            
            createWorld();
            animate();
            
            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
            
            document.addEventListener('contextmenu', e => e.preventDefault());
            
            setTimeout(() => {
                document.getElementById('loading').style.display = 'none';
            }, 1000);
            
        })();
    </script>
</body>
</html>
